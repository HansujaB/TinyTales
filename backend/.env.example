# AI APIs
GEMINI_API_KEY=your_gemini_api_key
GROQ_API_KEY=your_groq_api_key

# Firebase
FIREBASE_PROJECT_ID=tinytales-xxx
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# MongoDB
MONGODB_URL=mongodb+srv://user:password@cluster0.mongodb.net/tinytales
MONGODB_DB_NAME=tinytales

# Redis (optional — set to empty to skip)
REDIS_URL=redis://localhost:6379

# App
CORS_ORIGINS=http://localhost:5173,https://tinytales.app
ENVIRONMENT=development
FRONTEND_URL=http://localhost:5173
